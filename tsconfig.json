{
  "extends": "@tsconfig/node24/tsconfig.json",
  "compilerOptions": {
    "resolveJsonModule": true,
    "rootDir": "./src",
    "outDir": "./dist",

    "removeComments": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "types": ["node"]
  },
  "include": ["src/**/*"],
}
